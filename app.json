{
  "expo": {
    "name": "todo-app",
    "slug": "Todo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "todoapp",
    "userInterfaceStyle": "automatic",

    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#05243E"
      },
      "package": "com.jameel_sikandar.Todo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Checkmark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FF0000",
          "dark": {
            "backgroundColor": "#FF0000"
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": false
    }
  }
}